{
  "name": "lostark-arkgrid-gem-locator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:github": "vite build --config vite.config.github.ts",
    "build:tencent": "vite build --config vite.config.tencent.ts",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "prettier --write .",
    "deploy": "gh-pages -d dist",
    "generate:sprite": "node scripts/generate-sprite.cjs",
    "generate:api": "node scripts/generate-openapi.cjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@tsconfig/svelte": "^5.0.5",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "cross-env": "^10.1.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "spritesmith": "^3.5.1",
    "svelte": "^5.39.6",
    "svelte-check": "^4.3.2",
    "swagger-typescript-api": "^13.2.18",
    "typescript": "~5.9.3",
    "vite": "^7.1.12"
  },
  "dependencies": {
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@types/dom-mediacapture-transform": "^0.1.11",
    "@zerodevx/svelte-toast": "^0.9.6",
    "svelte-persisted-state": "^1.2.0"
  }
}
